---

<footer class="footer">
  <span>&copy; {new Date().getFullYear()} <a href="/">半轻小屋</a></span>
</footer>

<a href="#top" aria-label="回到顶部" title="回到顶部 (Alt + G)" class="top-link" id="top-link" accesskey="g">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 6" fill="currentColor">
    <path d="M12 6H0l6-6z" />
  </svg>
</a>

<script>
  // Smooth anchor scrolling
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const id = (this as HTMLAnchorElement).getAttribute('href')!.substring(1);
      const el = document.querySelector(`[id='${decodeURIComponent(id)}']`);
      if (!el) return;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      el.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
      if (id === 'top') {
        history.replaceState(null, '', ' ');
      } else {
        history.pushState(null, '', `#${id}`);
      }
    });
  });

  // Back-to-top button visibility
  const topBtn = document.getElementById('top-link');
  if (topBtn) {
    window.addEventListener('scroll', () => {
      const shown = document.documentElement.scrollTop > 800;
      topBtn.style.visibility = shown ? 'visible' : 'hidden';
      topBtn.style.opacity = shown ? '1' : '0';
    });
  }
</script>
